<link rel="stylesheet" href="/css/style.css">

<body>
    <div class="dashboard">
        <h2>Generate QR Code</h2>
        <form action="/qr/generate" method="POST"> <input type="text" name="qrData" placeholder="Enter link or text">
            <select name="qrType">
                <option value="url">URL</option>
                <option value="text">Text</option>
            </select>

            <button type="submit">Create QR</button>

        </form>
        <div class="qr-list">

            <% qrs.forEach(function(item){ %>

                <div class="qr-card"> <img src="<%= item.qrImage %>">
                    <p>
                        <%= item.data %>
                    </p>
                    <p>Total Scans: <%= item.scanCount %>
                    </p>
                </div>

                <% }) %>

        </div>
    </div>
</body>